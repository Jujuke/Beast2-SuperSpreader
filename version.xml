<package name="SuperSpreader" version="0.0.1">
    <depends on="BEAST.base" atleast="2.7.0" atmost="2.7.9"/>
    <depends on="BEAST.app" atleast="2.7.0" atmost="2.7.9"/>
    <depends on="SA" atleast="2.1.0"/>
    <depends on="BDMM-Prime" atleast="2.7.0"/>

    <service type="beast.base.core.BEASTInterface">
        <provider classname="superspreader.parameterization.SuperSpreaderParameterization"/>
        <provider classname="superspreader.parameterization.SkylineScalarWithCommonTimeParameter"/>
        <provider classname="superspreader.parameterization.TimeOnlySkylineParameter"/>
    </service>
    <service type="beastfx.app.inputeditor.InputEditor">
        <provider classname="superspreader.beauti.SkylineScalarWithCommonTimeInputEditor"/>
        <provider classname="superspreader.beauti.TimeOnlySkylineInputEditor"/>
    </service>
</package>